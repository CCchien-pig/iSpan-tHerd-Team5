@model List<FlexBackend.ORD.Rcl.Areas.ORD.ViewModels.CartItemVM>

@{
    ViewData["Title"] = "購物車測試";
}

<!-- ✅ 引入 Bootstrap Icons 和 SweetAlert2 -->
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/sweetalert2@11/dist/sweetalert2.min.css">

<div class="container mt-4">
    <h2>
        <i class="bi bi-cart3"></i> 購物車
    </h2>

    @if (!Model.Any())
    {
        <div class="alert alert-info mt-3">
            <i class="bi bi-info-circle"></i> 購物車是空的
        </div>
    }
    else
    {
        <table class="table table-striped table-hover mt-3">
            <thead class="table-dark">
                <tr>
                    <th>商品名稱</th>
                    <th>規格</th>
                    <th>單價</th>
                    <th style="width: 200px;">數量</th>
                    <th>小計</th>
                    <th style="width: 100px;">操作</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr data-product-id="@item.ProductId">
                        <td>@item.ProductName</td>
                        <td>
                            <span class="badge bg-secondary">@item.SpecCode</span>
                        </td>
                        <td>NT$ <span class="unit-price">@item.UnitPrice.ToString("N0")</span></td>
                        <td>
                            <div class="input-group input-group-sm">
                                <button class="btn btn-outline-secondary btn-minus" type="button">
                                    <i class="bi bi-dash"></i>
                                </button>
                                <input type="text" class="form-control text-center qty-input"
                                       value="@item.Qty" readonly>
                                <button class="btn btn-outline-secondary btn-plus" type="button">
                                    <i class="bi bi-plus"></i>
                                </button>
                            </div>
                        </td>
                        <td>
                            <strong>NT$ <span class="subtotal">@item.Subtotal.ToString("N0")</span></strong>
                        </td>
                        <td>
                            <button class="btn btn-danger btn-sm btn-remove">
                                <i class="bi bi-trash"></i>
                            </button>
                        </td>
                    </tr>
                }
            </tbody>
            <tfoot>
                <tr class="table-light">
                    <td colspan="4" class="text-end"><strong>總計:</strong></td>
                    <td colspan="2">
                        <strong class="text-primary fs-5">
                            NT$ <span id="total-amount">@Model.Sum(x => x.Subtotal).ToString("N0")</span>
                        </strong>
                    </td>
                </tr>
            </tfoot>
        </table>

        <div class="text-end mt-3">
            <button id="btn-checkout" class="btn btn-primary btn-lg">
                <i class="bi bi-cart-check"></i> 前往結帳
            </button>
        </div>
    }
</div>

@section Scripts {
    <!-- ✅ 引入 SweetAlert2 JS -->
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

    <script>
        $(document).ready(function () {
            const userNumberId = 1000;

            // ========================================
            // 加數量
            // ========================================
            $('.btn-plus').click(function () {
                const row = $(this).closest('tr');
                const productId = row.data('product-id');
                updateQuantity(productId, 1, row);
            });

            // ========================================
            // 減數量
            // ========================================
            $('.btn-minus').click(function () {
                const row = $(this).closest('tr');
                const productId = row.data('product-id');
                updateQuantity(productId, -1, row);
            });

            // ========================================
            // 移除商品
            // ========================================
            $('.btn-remove').click(function () {
                const row = $(this).closest('tr');
                const productId = row.data('product-id');
                removeItem(productId, row);
            });

            // ========================================
            // 結帳
            // ========================================
            $('#btn-checkout').click(function () {
                Swal.fire({
                    title: '確定要結帳嗎?',
                    icon: 'question',
                    showCancelButton: true,
                    confirmButtonColor: '#3085d6',
                    cancelButtonColor: '#d33',
                    confirmButtonText: '確定結帳',
                    cancelButtonText: '取消'
                }).then((result) => {
                    if (result.isConfirmed) {
                        const btn = $('#btn-checkout');
                        btn.prop('disabled', true).html('<i class="bi bi-hourglass-split"></i> 處理中...');

                        $.ajax({
                            url: '@Url.Action("CheckoutFromCart", "CartTest", new { area = "ORD" })',
                            type: 'POST',
                            data: { userNumberId: userNumberId },
                            success: function (response) {
                                if (response.success) {
                                    Swal.fire({
                                        icon: 'success',
                                        title: '結帳成功!',
                                        html: `<p>${response.message}</p><p>訂單編號: <strong>${response.orderId}</strong></p>`,
                                        confirmButtonText: '確定'
                                    }).then(() => {
                                        location.reload();
                                    });
                                } else {
                                    Swal.fire({
                                        icon: 'error',
                                        title: '結帳失敗',
                                        text: response.message,
                                        confirmButtonText: '確定'
                                    });
                                    btn.prop('disabled', false).html('<i class="bi bi-cart-check"></i> 前往結帳');
                                }
                            },
                            error: function () {
                                Swal.fire({
                                    icon: 'error',
                                    title: '發生錯誤',
                                    text: '結帳時發生錯誤，請稍後再試',
                                    confirmButtonText: '確定'
                                });
                                btn.prop('disabled', false).html('<i class="bi bi-cart-check"></i> 前往結帳');
                            }
                        });
                    }
                });
            });

            // ========================================
            // 更新數量的函式
            // ========================================
            function updateQuantity(productId, delta, row) {
                $.ajax({
                    url: '@Url.Action("UpdateQuantity", "CartTest", new { area = "ORD" })',
                    type: 'POST',
                    data: {
                        productId: productId,
                        delta: delta,
                        userNumberId: userNumberId
                    },
                    success: function (response) {
                        if (response.success) {
                            if (response.removed) {
                                // 商品已被移除
                                row.fadeOut(300, function () {
                                    $(this).remove();
                                    updateTotal();
                                });

                                // ✅ SweetAlert 提示
                                Swal.fire({
                                    icon: 'info',
                                    title: '商品已移除',
                                    toast: true,
                                    position: 'top-end',
                                    showConfirmButton: false,
                                    timer: 2000,
                                    timerProgressBar: true
                                });
                            } else {
                                // 更新數量和小計
                                row.find('.qty-input').val(response.newQty);
                                row.find('.subtotal').text(response.newSubtotal.toLocaleString('zh-TW', {
                                    minimumFractionDigits: 0,
                                    maximumFractionDigits: 0
                                }));
                                updateTotal();
                            }
                        } else {
                            // ✅ SweetAlert 錯誤提示
                            Swal.fire({
                                icon: 'warning',
                                title: '更新失敗',
                                text: response.message,
                                toast: true,
                                position: 'top-end',
                                showConfirmButton: false,
                                timer: 3000,
                                timerProgressBar: true
                            });
                        }
                    },
                    error: function () {
                        Swal.fire({
                            icon: 'error',
                            title: '發生錯誤',
                            text: '更新數量時發生錯誤',
                            toast: true,
                            position: 'top-end',
                            showConfirmButton: false,
                            timer: 3000
                        });
                    }
                });
            }

            // ========================================
            // 移除商品的函式
            // ========================================
            function removeItem(productId, row) {
                Swal.fire({
                    title: '確定要移除此商品嗎?',
                    icon: 'warning',
                    showCancelButton: true,
                    confirmButtonColor: '#d33',
                    cancelButtonColor: '#3085d6',
                    confirmButtonText: '確定移除',
                    cancelButtonText: '取消'
                }).then((result) => {
                    if (result.isConfirmed) {
                        $.ajax({
                            url: '@Url.Action("RemoveItem", "CartTest", new { area = "ORD" })',
                            type: 'POST',
                            data: {
                                productId: productId,
                                userNumberId: userNumberId
                            },
                            success: function (response) {
                                if (response.success) {
                                    row.fadeOut(300, function () {
                                        $(this).remove();
                                        updateTotal();
                                    });

                                    // ✅ SweetAlert 成功提示
                                    Swal.fire({
                                        icon: 'success',
                                        title: '已移除',
                                        text: response.message,
                                        toast: true,
                                        position: 'top-end',
                                        showConfirmButton: false,
                                        timer: 2000,
                                        timerProgressBar: true
                                    });
                                } else {
                                    Swal.fire({
                                        icon: 'error',
                                        title: '移除失敗',
                                        text: response.message
                                    });
                                }
                            },
                            error: function () {
                                Swal.fire({
                                    icon: 'error',
                                    title: '發生錯誤',
                                    text: '移除商品時發生錯誤'
                                });
                            }
                        });
                    }
                });
            }

            // ========================================
            // 更新總計金額
            // ========================================
            function updateTotal() {
                let total = 0;
                $('tbody tr').each(function () {
                    const subtotalText = $(this).find('.subtotal').text().replace(/,/g, '');
                    const subtotal = parseFloat(subtotalText) || 0;
                    total += subtotal;
                });

                $('#total-amount').text(total.toLocaleString('zh-TW', {
                    minimumFractionDigits: 0,
                    maximumFractionDigits: 0
                }));

                // 如果購物車空了,重新載入頁面
                if ($('tbody tr').length === 0) {
                    setTimeout(() => location.reload(), 500);
                }
            }
        });
    </script>
}